{
  "permissions": {
    "allow": [
      "Bash(nx *)",
      "Bash(pnpm *)",
      "Bash(npm run *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Edit(./.env)"
    ],
    "ask": [
      "Bash(rm -rf *)"
    ],
    "deny": [
      "Bash(git push *)"
    ]
  },
  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      "apps/pharos-lab/node_modules",
      "apps/task-manager/node_modules",
      ".nx"
    ],
    "sparsePaths": [
      "apps/pharos-lab",
      "apps/task-manager"
    ]
  },
  "enabledPlugins": {
    "harness@harness-marketplace": true
  },
  "language": "korean",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-commit-gate.sh",
            "timeout": 60,
            "statusMessage": "커밋 전 타입 체크 + FSD 검사 중..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-fsd-check.sh",
            "async": true,
            "timeout": 30
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "backend|database|frontend|pm|qa|gc",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/agent-notify.sh",
            "async": true,
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "backend|database|frontend|pm|qa|gc",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/agent-notify.sh",
            "async": true,
            "timeout": 10
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/task-complete-notify.sh",
            "async": true,
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pipeline-enforcer.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
