{
  "permissions": {
    "allow": [
      "Bash(nx *)",
      "Bash(pnpm *)",
      "Bash(npm run *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Edit(./.env)"
    ],
    "ask": [
      "Bash(rm -rf *)"
    ],
    "deny": [
      "Bash(git push *)"
    ]
  },
  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      "apps/pharos-lab/node_modules",
      "apps/task-manager/node_modules",
      ".nx"
    ],
    "sparsePaths": [
      "apps/pharos-lab",
      "apps/task-manager"
    ]
  },
  "enabledPlugins": {
    "harness@harness-marketplace": true
  },
  "language": "korean",
  "hooks": {
    "SubagentStart": [
      {
        "matcher": "backend|database|frontend|pm|qa",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/agent-notify.sh",
            "async": true,
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "backend|database|frontend|pm|qa",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/agent-notify.sh",
            "async": true,
            "timeout": 10
          }
        ]
      }
    ]
  }
}
